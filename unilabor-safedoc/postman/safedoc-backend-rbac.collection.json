    {
      "name": "40 Negative Permission Checks",
      "item": [
        {
          "name": "Viewer cannot create category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{viewerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Viewer should fail\"\n}"
            },
            "url": "{{baseUrl}}/api/categories"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Viewer cannot upload document",
          "request": {
            "method": "POST",
            "header": [
              {

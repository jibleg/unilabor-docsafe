            "url": "{{baseUrl}}/api/categories?page={{page}}&limit={{limit}}&search={{categorySearch}}&includeInactive={{includeInactive}}"
          }
        },
        {
          "name": "Update Category (EDITOR)",
          "request": {
            "method": "PATCH",
            "header": [

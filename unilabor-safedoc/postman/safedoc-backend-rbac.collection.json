                "key": "Authorization",
                "value": "Bearer {{editorToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/api/categories/{{editorCategoryId}}/status"
          }
        },
        {
          "name": "Upload Document (EDITOR)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{editorToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{pdfFilePath}}"
                },
                {
                  "key": "category_id",
                  "value": "{{editorCategoryId}}",
                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "{{documentTitle}}",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "{{documentDescription}}",
                  "type": "text"
                },
                {
                  "key": "publish_date",
                  "value": "{{documentPublishDate}}",
                  "type": "text"
                },
                {
                  "key": "expiry_date",
                  "value": "{{documentExpiryDate}}",
                  "type": "text"
                }
              ]
            },
            "url": "{{baseUrl}}/api/documents/upload"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && data.docId) {",
                  "  pm.environment.set('documentId', data.docId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Documents (EDITOR)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{editorToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/documents?includeInactive={{documentsIncludeInactive}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const docs = pm.response.json();",
                  "if (Array.isArray(docs) && docs.length > 0) {",
                  "  if (docs[0].id) {",
                  "    pm.environment.set('documentId', docs[0].id);",
                  "  }",
                  "  if (docs[0].filename) {",
                  "    const base = String(docs[0].filename).split(/[\\\\/]/).pop();",
                  "    pm.environment.set('documentFilename', base);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "View Document (EDITOR)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{editorToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/documents/view/{{documentFilename}}"
          }
        },
        {
          "name": "Update Document Metadata (EDITOR)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{editorToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{documentTitleUpdated}}\",\n  \"description\": \"{{documentDescriptionUpdated}}\",\n  \"publish_date\": \"{{documentPublishDateUpdated}}\",\n  \"expiry_date\": \"{{documentExpiryDateUpdated}}\",\n  \"category_id\": \"{{editorCategoryId}}\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/api/documents/{{documentId}}"
          }
        },
        {
          "name": "Toggle Document Status (EDITOR)",
          "request": {
            "method": "PATCH",

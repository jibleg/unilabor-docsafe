  "item": [
    {
      "name": "00 Auth",
      "item": [
        {
          "name": "Login ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.environment.set('adminToken', data.token);",
                  "}",
                  "if (data && data.user && data.user.id) {",
                  "  pm.environment.set('adminUserId', data.user.id);",
                  "}",
                  "if (data && data.user && typeof data.user.mustChangePassword !== 'undefined') {",
                  "  pm.environment.set('adminMustChangePassword', String(data.user.mustChangePassword));",
                  "}"
                ]
              }
            }
          ]
        },
